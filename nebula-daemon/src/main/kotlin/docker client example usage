package nebula

import kotlinx.coroutines.flow.collect
import kotlinx.coroutines.runBlocking
import me.devnatan.dockerkt.DockerClient
import me.devnatan.dockerkt.DockerResponseException
import me.devnatan.dockerkt.models.PortBinding
import me.devnatan.dockerkt.models.container.exposedPort
import me.devnatan.dockerkt.models.container.hostConfig
import me.devnatan.dockerkt.models.portBindings
import me.devnatan.dockerkt.resource.container.create
import me.devnatan.dockerkt.resource.container.remove
import org.slf4j.LoggerFactory

private val logger = LoggerFactory.getLogger("NebulaD")

private const val HOST_PORT: UShort = 40000u
private const val CONTAINER_PORT: UShort = 25565u
private const val MAX_ATTEMPTS = 20

fun main() = runBlocking {
    val client = DockerClient { forCurrentPlatform() }

    logger.info("Pulling image …")
    client.images.pull("busybox:latest").collect()

    val allCreated = mutableListOf<String>()

    data class Attempt(
        val index: Int,
        val containerId: String,
        val createSucceeded: Boolean,
        val startSucceeded: Boolean,
        val error: String,
    )

    val results = mutableListOf<Attempt>()

    try {
        run {
            repeat(MAX_ATTEMPTS) { index ->
                logger.info("--- Attempt #$index — trying to bind host port $HOST_PORT ---")

                // ── STEP 1: create ────────────────────────────────────────────
                // Declared as a non-nullable `val` and assigned inside the try block.
                // If create throws, the catch executes `return@repeat` (which is
                // typed as Nothing), so Kotlin's definite-assignment analysis
                // guarantees `containerId` is always initialized after this block.
                val containerId: String
                try {
                    containerId = client.containers.create {
                        image = "busybox:latest"
                        command = listOf("sh", "-c", "sleep 600")
                        exposedPort(CONTAINER_PORT)

                        hostConfig {
                            portBindings(CONTAINER_PORT) {
                                add(PortBinding(ip = "0.0.0.0", port = HOST_PORT))
                            }
                        }
                    }
                    allCreated += containerId
                    logger.info("#$index  CREATE  ✓  id=$containerId")
                } catch (e: DockerResponseException) {
                    // Named arguments avoid the "Boolean literal without parameter name" warning.
                    results += Attempt(
                        index = index,
                        containerId = "<none>",
                        createSucceeded = false,
                        startSucceeded = false,
                        error = e.message ?: "unknown error",
                    )
                    logger.warn("#$index  CREATE  ✗  ${e.message ?: "unknown error"}")
                    return@repeat
                }

                // ── STEP 2: start ─────────────────────────────────────────────
                var startOk = false
                var startError = ""

                try {
                    client.containers.start(containerId)
                    startOk = true
                    logger.info("#$index  START   ✓  container is running")
                } catch (e: DockerResponseException) {
                    startError = e.message ?: "unknown error"
                    val stillExists = runCatching {
                        client.containers.inspect(containerId)
                    }.isSuccess
                    logger.warn("#$index  START   ✗  error=\"$startError\"")
                    logger.warn("#$index           container still exists after failed start? $stillExists")
                    logger.warn("#$index           ↳ Proves Docker creates first; port binding happens on start.")
                }

                results += Attempt(
                    index = index,
                    containerId = containerId,
                    createSucceeded = true,
                    startSucceeded = startOk,
                    error = startError,
                )

                if (!startOk) {
                    logger.info("First port-conflict at attempt #$index — stopping.")
                    return@run
                }
            }
        }
    } finally {
        logger.info("=== Cleaning up ${allCreated.size} container(s) ===")
        allCreated.forEach { id ->
            runCatching {
                client.containers.remove(id) {
                    force = true
                    removeAnonymousVolumes = true
                }
            }.onSuccess { logger.info("Removed $id") }
                .onFailure  { logger.warn("Could not remove $id: ${it.message ?: "unknown"}") }
        }

        logger.info("\n=== Summary ===")
        results.forEach { r ->
            val status = when {
                !r.createSucceeded -> "CREATE failed"
                !r.startSucceeded  -> "CREATED but START failed  ← port conflict"
                else               -> "CREATED + STARTED OK"
            }
            val errorSuffix = r.error.takeIf { it.isNotEmpty() }?.let { "  [${it.take(120)}]" } ?: ""
            logger.info("#${r.index}  ${r.containerId.take(12)}  →  $status$errorSuffix")
        }
    }
}